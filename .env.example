# Full environment reference: docs/ENVIRONMENT.md

POSTGRES_DB=calendar_genie
POSTGRES_USER=ss_admin
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DATABASE_SSLMODE=

# Local Node runtime (npm scripts)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Container runtime (docker compose server service)
DOCKER_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

JWT_SECRET=replace-with-strong-random-secret
PORT=4000
CORS_ORIGIN=http://localhost:5173
SSO_OIDC_REDIRECT_URI=http://localhost:4000/api/v1/auth/sso/oidc/callback
SSO_OIDC_STATE_SECRET=
TRUST_PROXY=1
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_READ_RATE_LIMIT_MAX=120
PUBLIC_WRITE_RATE_LIMIT_MAX=30
METRICS_TOKEN=

# For development/testing only - forces email sending to fail, allowing you to test retry logic and abuse lockout without sending real emails
EMAIL_QUEUE_FORCE_FAILURE=false

# Abuse prevention settings
ABUSE_LOCKOUT_ENABLED=true
ABUSE_FAILURE_WINDOW_MS=900000
ABUSE_FAILURE_THRESHOLD=5
ABUSE_LOCKOUT_BASE_MS=300000
ABUSE_LOCKOUT_MAX_MS=3600000
ABUSE_CAPTCHA_AFTER_LOCKOUTS=2
# Idempotency settings
BOOKING_IDEMPOTENCY_TTL_HOURS=24
REFRESH_TOKEN_TTL_DAYS=30
JOB_QUEUE_POLL_INTERVAL_MS=1000
JOB_QUEUE_MAX_ATTEMPTS=5
JOB_QUEUE_BACKOFF_BASE_MS=5000
MICROSOFT_CALENDAR_SYNC_ENABLED=true
MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback
MICROSOFT_OAUTH_SCOPES=offline_access User.Read Calendars.ReadWrite
MICROSOFT_OAUTH_STATE_TTL_SECONDS=600
MICROSOFT_OAUTH_STATE_SECRET=
MICROSOFT_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/dashboard
MICROSOFT_OAUTH_ERROR_REDIRECT_URL=http://localhost:5173/dashboard
DATA_RETENTION_ENABLED=true
DATA_RETENTION_SWEEP_INTERVAL_MS=3600000
DATA_RETENTION_PII_DAYS=365
DATA_RETENTION_CANCELLED_BOOKING_DELETE_DAYS=730
DATA_RETENTION_IDEMPOTENCY_KEY_DELETE_DAYS=2
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@calendar-genie.local
RESEND_API_KEY=
BOOKING_PORTAL_BASE_URL=http://localhost:3000
EMAIL_QUEUE_FORCE_FAILURE=false
BACKUP_DIR=./backups

VITE_API_URL=/api
VITE_DEV_PROXY_TARGET=http://127.0.0.1:4000
API_UPSTREAM=http://server:4000

# Load testing helpers (optional)
LOADTEST_BASE_URL=http://127.0.0.1:4000
LOADTEST_API_BASE_PATH=/api/v1
LOADTEST_SHARE_TOKEN=
LOADTEST_PASSWORD=
LOADTEST_TIME_BLOCK_ID=
LOADTEST_DURATION_SECONDS=30
LOADTEST_VUS=10
LOADTEST_THINK_TIME_MS=20
LOADTEST_EMAIL_DOMAIN=example.com
