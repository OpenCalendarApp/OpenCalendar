# Azure baseline target: East US, prod baseline

# Frontend domain
APP_DOMAIN=https://calendar.example.com

# Client container runtime
API_UPSTREAM=http://<server-internal-origin>

# Server runtime
NODE_ENV=production
PORT=4000
TRUST_PROXY=1
CORS_ORIGIN=${APP_DOMAIN}
BOOKING_PORTAL_BASE_URL=${APP_DOMAIN}

# Database
POSTGRES_HOST=<private-postgres-host>
POSTGRES_PORT=5432
POSTGRES_DB=calendar_genie
POSTGRES_USER=<postgres-user>
POSTGRES_PASSWORD=<postgres-password>
DATABASE_SSLMODE=require
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=${DATABASE_SSLMODE}

# Security
JWT_SECRET=<key-vault-secret>
METRICS_TOKEN=<key-vault-secret>

# Email
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@calendar.example.com
RESEND_API_KEY=

# Microsoft calendar / SSO
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=${APP_DOMAIN}/api/auth/microsoft/callback
MICROSOFT_OAUTH_SUCCESS_REDIRECT_URL=${APP_DOMAIN}/dashboard
MICROSOFT_OAUTH_ERROR_REDIRECT_URL=${APP_DOMAIN}/dashboard
SSO_OIDC_REDIRECT_URI=${APP_DOMAIN}/api/v1/auth/sso/oidc/callback
